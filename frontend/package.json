{
    "name": "arch-stats_frontend",
    "type": "module",
    "version": "0.0.0",
    "private": true,
    "scripts": {
        "dev": "vite",
        "build": "vue-tsc -b && vite build",
        "preview": "vite preview",
        "lint": "eslint --fix .",
        "clear:vite_cache": "rm -rf ./node_modules/.vite",
        "generate:types": "../scripts/generate_fe_types.bash",
        "test": "NODE_OPTIONS='--localstorage-file=./.vitest-localstorage' vitest run",
        "test:watch": "NODE_OPTIONS='--localstorage-file=./.vitest-localstorage' vitest",
        "test:coverage": "NODE_OPTIONS='--localstorage-file=./.vitest-localstorage' vitest run --coverage",
        "type-check": "vue-tsc --noEmit"
    },
    "dependencies": {
        "vue": "^3.5.29",
        "vue-router": "^5.0.3"
    },
    "devDependencies": {
        "@antfu/eslint-config": "^7.6.1",
        "@tailwindcss/vite": "^4.2.1",
        "@types/node": "^25.3.3",
        "@vitejs/plugin-vue": "^6.0.4",
        "@vitest/coverage-v8": "^4.0.18",
        "@vue/test-utils": "^2.4.6",
        "@vue/tsconfig": "^0.8.1",
        "autoprefixer": "^10.4.27",
        "baseline-browser-mapping": "^2.10.0",
        "eslint": "^10.0.2",
        "jsdom": "^28.1.0",
        "openapi-typescript": "^7.13.0",
        "postcss": "^8.5.6",
        "tailwindcss": "^4.2.1",
        "typescript": "~5.9.3",
        "vite": "^7.3.1",
        "vitest": "^4.0.18",
        "vue-tsc": "^3.2.5"
    }
}
